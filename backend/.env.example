# PostgreSQL connection string (dari Railway, Supabase, dll)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secret - ganti dengan random string panjang (min 32 karakter)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="ganti-dengan-string-random-minimal-32-karakter"

# Port server (Railway otomatis set ini)
PORT=5000

# URL Frontend produksi (untuk CORS)
FRONTEND_URL="https://hurr-store.vercel.app"

# Environment
NODE_ENV="production"

# Midtrans Payment Gateway
# Dapatkan dari: https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY="Mid-server-XXXXXXXXXXXXXXXX"
MIDTRANS_CLIENT_KEY="Mid-client-XXXXXXXXXXXXXXXX"

# URL Backend (untuk OAuth callback URL)
BACKEND_URL="https://hurr-backend-production.up.railway.app"

# Session Secret (untuk express-session selama OAuth flow)
SESSION_SECRET="ganti-dengan-random-string-panjang"

# Google OAuth (dari Google Cloud Console → Credentials → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Facebook OAuth (dari Meta Developer Console → App → Settings → Basic)
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

