# PostgreSQL connection string (dari Railway, Supabase, dll)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secret - ganti dengan random string panjang (min 32 karakter)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="ganti-dengan-string-random-minimal-32-karakter"

# Port server (Railway otomatis set ini)
PORT=5000

# URL Frontend produksi (untuk CORS)
FRONTEND_URL="https://hurr-store.vercel.app"

# Environment
NODE_ENV="production"

# Midtrans Payment Gateway
# Dapatkan dari: https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY="Mid-server-XXXXXXXXXXXXXXXX"
MIDTRANS_CLIENT_KEY="Mid-client-XXXXXXXXXXXXXXXX"

